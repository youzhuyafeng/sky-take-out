<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.UserMapper">
    <select id="countUser" resultType="java.util.Map">
        select
        <foreach collection="dateQueryList" index="idx" separator="," item="date">
            sum(
            case when
            <if test="date['end'] != null">
                create_time &lt; #{date.end}
            </if>
            <if test="date['begin'] != null">
                and create_time &gt; #{date.begin}
            </if>
            then 1 else 0 end) as date_${idx}
        </foreach>
        from user
    </select>
    <select id="countByMap" resultType="java.lang.Integer">
        select
        sum(
        case when
        <if test="map['end'] != null">
            create_time &lt; #{map.end}
        </if>
        <if test="map['begin'] != null">
            and create_time &gt; #{map.begin}
        </if>
        then 1 else 0 end)
        from user
    </select>
</mapper>